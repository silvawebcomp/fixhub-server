generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int         @id @default(autoincrement())
  name      String
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  customers Customer[]
  inventory Inventory[]
  repairs   Repair[]
  invoices  Invoice[]
  notifications NotificationLog[]
  stockMovements StockMovement[]
}

model Repair {
  id                 Int                   @id @default(autoincrement())
  customer           String
  device             String
  status             String
  notes              String?
  createdAt          DateTime              @default(now())
  userId             Int
  ticketNumber       String?               @unique
  customerPhone      String?
  customerEmail      String?
  deviceBrand        String?
  deviceModel        String?
  serialNumber       String?
  issue              String?
  priority           String                @default("Normal")
  assignedTechnician String?
  estimatedCost      Float?
  finalCost          Float?
  dueDate            DateTime?
  completedAt        DateTime?
  updatedAt          DateTime              @default(now()) @updatedAt
  invoice            Invoice?
  user               User                  @relation(fields: [userId], references: [id])
  statusHistory      RepairStatusHistory[]
  notifications      NotificationLog[]
}

model RepairStatusHistory {
  id        Int      @id @default(autoincrement())
  status    String
  note      String?
  createdAt DateTime @default(now())
  repairId  Int
  repair    Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([repairId, createdAt])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Inventory {
  id           Int             @id @default(autoincrement())
  name         String
  quantity     Int
  price        Float
  sku          String?
  category     String?
  supplier     String?
  location     String?
  reorderLevel Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt
  userId       Int
  user         User            @relation(fields: [userId], references: [id])
  movements    StockMovement[]

  @@index([userId, category])
  @@index([userId, sku])
}

model StockMovement {
  id          Int       @id @default(autoincrement())
  inventoryId Int
  userId      Int
  type        String
  quantity    Int
  previousQty Int
  newQty      Int
  unitCost    Float?
  reason      String?
  createdAt   DateTime  @default(now())
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([inventoryId, createdAt])
  @@index([userId, createdAt])
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  repairId      Int           @unique
  userId        Int
  labourCost    Float         @default(0)
  partsCost     Float         @default(0)
  discount      Float         @default(0)
  tax           Float         @default(0)
  subtotal      Float
  total         Float
  amountPaid    Float         @default(0)
  balance       Float
  paymentMethod String?
  paymentStatus String        @default("Pending")
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  repair        Repair        @relation(fields: [repairId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]

  @@index([userId, createdAt])
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Int
  unitPrice   Float
  total       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  amount    Float
  method    String
  reference String?
  notes     String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paidAt])
}

model NotificationLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  repairId  Int?
  channel   String
  recipient String
  subject   String?
  message   String
  status    String   @default("Prepared")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  repair    Repair?  @relation(fields: [repairId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([repairId, createdAt])
}
