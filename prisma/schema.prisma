generator client {

  provider = "prisma-client-js"

}

datasource db {

  provider = "postgresql"

  url      = env("DATABASE_URL")

}

model User {

  id         Int         @id @default(autoincrement())

  name       String

  email      String      @unique

  password   String

  createdAt  DateTime    @default(now())

  repairs    Repair[]

  customers  Customer[]

  inventory  Inventory[]

}

model Repair {

  id                 Int                   @id @default(autoincrement())
  ticketNumber       String?               @unique
  customer           String
  customerPhone      String?
  customerEmail      String?
  device             String
  deviceBrand        String?
  deviceModel        String?
  serialNumber       String?
  issue              String?
  status             String                @default("Received")
  priority           String                @default("Normal")
  assignedTechnician String?
  estimatedCost      Float?
  finalCost          Float?
  dueDate            DateTime?
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  userId             Int
  user               User                  @relation(fields: [userId], references: [id])
  statusHistory      RepairStatusHistory[]

}

model RepairStatusHistory {
  id        Int      @id @default(autoincrement())
  status    String
  note      String?
  createdAt DateTime @default(now())
  repairId  Int
  repair    Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([repairId, createdAt])
}

model Customer {

  id         Int       @id @default(autoincrement())

  name       String

  phone      String

  email      String?

  createdAt  DateTime  @default(now())

  userId     Int

  user       User      @relation(fields: [userId], references: [id])

}

model Inventory {

  id         Int       @id @default(autoincrement())

  name       String

  quantity   Int

  price      Float

  createdAt  DateTime  @default(now())

  userId     Int

  user       User      @relation(fields: [userId], references: [id])

}
