generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int         @id @default(autoincrement())
  name      String
  email     String      @unique
  password  String
  role      String      @default("Owner")
  workspaceOwnerId Int?
  createdAt DateTime    @default(now())
  workspaceOwner User?  @relation("WorkspaceMembers", fields: [workspaceOwnerId], references: [id])
  workspaceMembers User[] @relation("WorkspaceMembers")
  branches  Branch[]
  customers Customer[]
  inventory Inventory[]
  repairs   Repair[]
  invoices  Invoice[]
  notifications NotificationLog[]
  stockMovements StockMovement[]
  auditLogs AuditLog[]
  passwordResetCodes PasswordResetCode[]

  @@index([workspaceOwnerId])
  @@index([role])
}

model PasswordResetCode {
  id        Int       @id @default(autoincrement())
  email     String
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([email, expiresAt])
}

model Branch {
  id          Int         @id @default(autoincrement())
  name        String
  address     String?
  phone       String?
  managerName String?
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt
  userId      Int
  user        User        @relation(fields: [userId], references: [id])
  repairs     Repair[]
  inventory   Inventory[]

  @@unique([userId, name])
  @@index([userId, isDefault])
}

model Repair {
  id                 Int                   @id @default(autoincrement())
  customer           String
  device             String
  status             String
  notes              String?
  attachment         String?
  createdAt          DateTime              @default(now())
  userId             Int
  branchId           Int?
  ticketNumber       String?               @unique
  customerPhone      String?
  customerEmail      String?
  deviceBrand        String?
  deviceModel        String?
  serialNumber       String?
  issue              String?
  priority           String                @default("Normal")
  assignedTechnician String?
  estimatedCost      Float?
  finalCost          Float?
  dueDate            DateTime?
  completedAt        DateTime?
  updatedAt          DateTime              @default(now()) @updatedAt
  invoice            Invoice?
  user               User                  @relation(fields: [userId], references: [id])
  branch             Branch?               @relation(fields: [branchId], references: [id], onDelete: SetNull)
  statusHistory      RepairStatusHistory[]
  notifications      NotificationLog[]

  @@index([userId, branchId])
}

model RepairStatusHistory {
  id        Int      @id @default(autoincrement())
  status    String
  note      String?
  createdAt DateTime @default(now())
  repairId  Int
  repair    Repair   @relation(fields: [repairId], references: [id], onDelete: Cascade)

  @@index([repairId, createdAt])
}

model Customer {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String
  email        String?
  profilePhoto String?
  createdAt    DateTime @default(now())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
}

model Inventory {
  id           Int             @id @default(autoincrement())
  name         String
  quantity     Int
  price        Float
  sku          String?
  category     String?
  supplier     String?
  location     String?
  reorderLevel Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt
  userId       Int
  branchId     Int?
  user         User            @relation(fields: [userId], references: [id])
  branch       Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  movements    StockMovement[]

  @@index([userId, category])
  @@index([userId, sku])
  @@index([userId, branchId])
}

model StockMovement {
  id          Int       @id @default(autoincrement())
  inventoryId Int
  userId      Int
  type        String
  quantity    Int
  previousQty Int
  newQty      Int
  unitCost    Float?
  reason      String?
  createdAt   DateTime  @default(now())
  inventory   Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id])

  @@index([inventoryId, createdAt])
  @@index([userId, createdAt])
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  repairId      Int           @unique
  userId        Int
  labourCost    Float         @default(0)
  partsCost     Float         @default(0)
  discount      Float         @default(0)
  tax           Float         @default(0)
  subtotal      Float
  total         Float
  amountPaid    Float         @default(0)
  balance       Float
  paymentMethod String?
  paymentStatus String        @default("Pending")
  notes         String?
  attachment    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  repair        Repair        @relation(fields: [repairId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]

  @@index([userId, createdAt])
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Int
  unitPrice   Float
  total       Float
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  amount    Float
  method    String
  reference String?
  notes     String?
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paidAt])
}

model NotificationLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  repairId  Int?
  channel   String
  recipient String
  subject   String?
  message   String
  status    String   @default("Prepared")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  repair    Repair?  @relation(fields: [repairId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([repairId, createdAt])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String
  entityId  Int?
  details   Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

model BetaFeedback {
  id             Int      @id @default(autoincrement())
  userId         Int
  authorId       Int?
  authorName     String?
  authorEmail    String?
  category       String   @default("General")
  rating         Int?
  message        String
  page           String?
  status         String   @default("New")
  contactConsent Boolean  @default(false)
  userAgent      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  @@index([userId, status, createdAt])
  @@index([authorId, createdAt])
}
